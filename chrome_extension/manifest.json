{
    "manifest_version": 3,
    "name": "X Scraper Extension",
    "version": "1.0",
    "description": "Scrape tweets and users from X by scrolling",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "*://*.x.com/*",
        "*://*.twitter.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.x.com/*",
                "*://*.twitter.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js"
            ],
            "matches": [
                "*://*.x.com/*",
                "*://*.twitter.com/*"
            ]
        }
    ]
}